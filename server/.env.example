# MongoDB Atlas connection string (free M0 cluster works fine).
# Example: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/raft-eats?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority&appName=NodeExpressProjects

# Server port (Render sets this automatically; default 4000 locally).
PORT=4000

# Comma-separated list of allowed origins for CORS.
# Set the Vercel URL after the frontend is deployed.
ALLOWED_ORIGINS=http://localhost:5173

# Demo: shorten the status transition delays during a presentation.
# Format: "RECEIVED:5000,PREPARING:10000,OUT_FOR_DELIVERY:15000" (in ms).
# Leave blank to use the production defaults.
STATUS_DELAYS_OVERRIDE=RECEIVED:5000,PREPARING:10000,OUT_FOR_DELIVERY:15000
